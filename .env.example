# Copy to .env.local and fill in real values.

# Neon Postgres connection string (from Neon console → Connection Details)
DATABASE_URL=""

# Integration tests connection string. MUST point to a different Neon
# branch than DATABASE_URL — the integration suite TRUNCATEs
# sessions_billing, blocked_times, and audit_log between tests. Create
# a dedicated branch in the Neon console, then point DATABASE_URL at
# it for a one-time `npm run db:migrate && npm run db:seed` setup.
# Leave empty to skip integration tests (locally and in CI).
INTEGRATION_DATABASE_URL=""

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Canonical app URL (Auth.js uses this to build OAuth callback URLs).
# Local: http://localhost:3000
# Vercel: must be set explicitly to the stable production alias
#   (e.g. https://pfa-cage-rentals.vercel.app) — Auth.js otherwise reads
#   Vercel's per-deployment VERCEL_URL which doesn't match the OAuth callback.
AUTH_URL=""

# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend API key (resend.com → API Keys → "Create API Key")
AUTH_RESEND_KEY=""

# Upstash Redis — magic-link rate limiting (src/lib/ratelimit.ts).
# Provision a free DB at console.upstash.com → Create Database (Redis,
# region near your Vercel function region), then copy the REST URL +
# token from the "REST API" tab. src/lib/ratelimit.ts treats requests
# as allowed if these are missing, so local dev can run without them.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sentry — error tracking
# DSN is safe to expose client-side (it's an ingest endpoint, not an auth key).
# Get DSN from: Sentry → Settings → Projects → pfa-cage-rentals → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=""

# Build-time only (for source-map upload, Vercel-side only).
# Get auth token from: Sentry → Settings → Auth Tokens
# Required scopes: project:read, project:releases, org:read
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# 1b #25 — SMS work-log reminders (Twilio). ALL OPTIONAL and DORMANT: leave
# unset and the capability is a no-op (the cron route returns disabled, no
# texts sent, nothing imports the send path). Set ALL of these at go-live to
# turn it on:
#   SMS_ENABLED        — must be exactly "true" to arm sending.
#   TWILIO_ACCOUNT_SID — Twilio Console → Account Info.
#   TWILIO_AUTH_TOKEN  — Twilio Console → Account Info (keep secret). ALSO gates
#                        the inbound webhook (/api/sms/inbound): while UNSET the
#                        webhook is INERT (200 empty TwiML, no state change);
#                        once set, every inbound POST must carry a valid
#                        X-Twilio-Signature or it is rejected 403.
#   TWILIO_FROM_NUMBER — the toll-free sending number in E.164, e.g. +18885551234.
#
# At go-live, point the Twilio number's "A message comes in" webhook to
#   https://pfaengine.com/api/sms/inbound   (HTTP POST)
# so STOP/HELP/START stay in sync with users.sms_opt_in / sms_opt_out, and
# enable Twilio Advanced Opt-Out per the SMS runbook. The signature is verified
# against that exact (fixed) URL — keep the webhook URL identical.
SMS_ENABLED=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Vercel cron auth — shared by the data-safe-snapshot + sms-reminders cron
# routes. OPTIONAL: when unset, those cron endpoints lock (401). Vercel
# auto-sends `Authorization: Bearer $CRON_SECRET` for scheduled invocations.
CRON_SECRET=""
