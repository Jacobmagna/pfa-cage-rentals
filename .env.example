# Copy to .env.local and fill in real values.

# Neon Postgres connection string (from Neon console → Connection Details)
DATABASE_URL=""

# Integration tests connection string. MUST point to a different Neon
# branch than DATABASE_URL — the integration suite TRUNCATEs
# sessions_billing, blocked_times, and audit_log between tests. Create
# a dedicated branch in the Neon console, then point DATABASE_URL at
# it for a one-time `npm run db:migrate && npm run db:seed` setup.
# Leave empty to skip integration tests (locally and in CI).
INTEGRATION_DATABASE_URL=""

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Canonical app URL (Auth.js uses this to build OAuth callback URLs).
# Local: http://localhost:3000
# Vercel: must be set explicitly to the stable production alias
#   (e.g. https://pfa-cage-rentals.vercel.app) — Auth.js otherwise reads
#   Vercel's per-deployment VERCEL_URL which doesn't match the OAuth callback.
AUTH_URL=""

# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend API key (resend.com → API Keys → "Create API Key")
AUTH_RESEND_KEY=""

# Sentry — error tracking
# DSN is safe to expose client-side (it's an ingest endpoint, not an auth key).
# Get DSN from: Sentry → Settings → Projects → pfa-cage-rentals → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=""

# Build-time only (for source-map upload, Vercel-side only).
# Get auth token from: Sentry → Settings → Auth Tokens
# Required scopes: project:read, project:releases, org:read
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
